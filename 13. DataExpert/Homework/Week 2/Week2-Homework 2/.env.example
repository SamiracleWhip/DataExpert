# GitHub API (optional — app works without this via mock data)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=owner/repo-name

# Email settings (optional — for SMTP delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your_app_password_here
EMAIL_RECIPIENT=stakeholders@example.com

# App settings
WEEK_START=monday         # Which day begins the weekly window
OUTPUT_DIR=output         # Where summary/email files are written
DATA_DIR=data             # Where mock data lives
